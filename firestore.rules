rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function stringMax(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function nonEmptyStringMax(value, maxLength) {
      return value is string
        && value.size() > 0
        && value.size() <= maxLength;
    }

    function chatExists(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId));
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && chatExists(chatId)
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function rateLimitMessageCreate(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return !(('lastSenderId' in chat)
        && chat.lastSenderId == request.auth.uid
        && ('lastMessageAt' in chat)
        && chat.lastMessageAt is timestamp
        && request.time < chat.lastMessageAt + duration.value(1, 's'));
    }

    function requestHasCurrentUserParticipant() {
      return signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50
        && request.auth.uid in request.resource.data.participants;
    }

    function publicProfileFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'name',
        'nameLower',
        'username',
        'usernameLower',
        'tag',
        'tagLower',
        'searchKeywords',
        'bio',
        'photoURL',
        'avatarUpdatedAt',
        'publicKey',
        'publicKeyUpdatedAt',
        'isOnline',
        'lastSeen',
        'createdAt',
        'updatedAt'
      ]);
    }

    function userFieldsOnly(keys) {
      return keys.hasOnly([
        'uid',
        'email',
        'emailLower',
        'phone',
        'name',
        'nameLower',
        'username',
        'usernameLower',
        'tag',
        'tagLower',
        'bio',
        'photoURL',
        'avatarUpdatedAt',
        'publicKey',
        'publicKeyUpdatedAt',
        'isOnline',
        'lastSeen',
        'createdAt',
        'updatedAt',
        'premiumStatus'
      ]);
    }

    function validUserFields(userId) {
      return (!('uid' in request.resource.data)
          || request.resource.data.uid == userId)
        && (!('email' in request.resource.data)
          || stringMax(request.resource.data.email, 254))
        && (!('emailLower' in request.resource.data)
          || stringMax(request.resource.data.emailLower, 254))
        && (!('phone' in request.resource.data)
          || stringMax(request.resource.data.phone, 32))
        && (!('name' in request.resource.data)
          || nonEmptyStringMax(request.resource.data.name, 100))
        && (!('nameLower' in request.resource.data)
          || stringMax(request.resource.data.nameLower, 100))
        && (!('username' in request.resource.data)
          || stringMax(request.resource.data.username, 100))
        && (!('usernameLower' in request.resource.data)
          || stringMax(request.resource.data.usernameLower, 100))
        && (!('tag' in request.resource.data)
          || stringMax(request.resource.data.tag, 100))
        && (!('tagLower' in request.resource.data)
          || stringMax(request.resource.data.tagLower, 100))
        && (!('bio' in request.resource.data)
          || stringMax(request.resource.data.bio, 500))
        && (!('photoURL' in request.resource.data)
          || request.resource.data.photoURL == null
          || stringMax(request.resource.data.photoURL, 2048))
        && (!('publicKey' in request.resource.data)
          || request.resource.data.publicKey == null
          || stringMax(request.resource.data.publicKey, 8000));
    }

    function validChangedUserFields(userId, changed) {
      return (!changed.hasAny(['uid'])
          || request.resource.data.uid == userId)
        && (!changed.hasAny(['email'])
          || stringMax(request.resource.data.email, 254))
        && (!changed.hasAny(['emailLower'])
          || stringMax(request.resource.data.emailLower, 254))
        && (!changed.hasAny(['phone'])
          || stringMax(request.resource.data.phone, 32))
        && (!changed.hasAny(['name'])
          || nonEmptyStringMax(request.resource.data.name, 100))
        && (!changed.hasAny(['nameLower'])
          || stringMax(request.resource.data.nameLower, 100))
        && (!changed.hasAny(['username'])
          || stringMax(request.resource.data.username, 100))
        && (!changed.hasAny(['usernameLower'])
          || stringMax(request.resource.data.usernameLower, 100))
        && (!changed.hasAny(['tag'])
          || stringMax(request.resource.data.tag, 100))
        && (!changed.hasAny(['tagLower'])
          || stringMax(request.resource.data.tagLower, 100))
        && (!changed.hasAny(['bio'])
          || stringMax(request.resource.data.bio, 500))
        && (!changed.hasAny(['photoURL'])
          || request.resource.data.photoURL == null
          || stringMax(request.resource.data.photoURL, 2048))
        && (!changed.hasAny(['publicKey'])
          || request.resource.data.publicKey == null
          || stringMax(request.resource.data.publicKey, 8000));
    }

    function validUserCreate(userId) {
      return isSelf(userId)
        && userFieldsOnly(request.resource.data.keys())
        && validUserFields(userId);
    }

    function validUserUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isSelf(userId)
        && userFieldsOnly(changed)
        && validChangedUserFields(userId, changed);
    }

    function validPublicProfileWrite(userId) {
      return isSelf(userId)
        && publicProfileFieldsOnly()
        && (!('uid' in request.resource.data)
          || request.resource.data.uid == userId)
        && (!('name' in request.resource.data)
          || nonEmptyStringMax(request.resource.data.name, 100))
        && (!('nameLower' in request.resource.data)
          || stringMax(request.resource.data.nameLower, 100))
        && (!('username' in request.resource.data)
          || stringMax(request.resource.data.username, 100))
        && (!('usernameLower' in request.resource.data)
          || stringMax(request.resource.data.usernameLower, 100))
        && (!('tag' in request.resource.data)
          || stringMax(request.resource.data.tag, 100))
        && (!('tagLower' in request.resource.data)
          || stringMax(request.resource.data.tagLower, 100))
        && (!('searchKeywords' in request.resource.data)
          || request.resource.data.searchKeywords is list)
        && (!('bio' in request.resource.data)
          || stringMax(request.resource.data.bio, 500))
        && (!('photoURL' in request.resource.data)
          || request.resource.data.photoURL == null
          || stringMax(request.resource.data.photoURL, 2048))
        && (!('publicKey' in request.resource.data)
          || request.resource.data.publicKey == null
          || stringMax(request.resource.data.publicKey, 8000));
    }

    function safeChatUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && request.auth.uid in resource.data.participants
        && !changed.hasAny(['participants', 'type', 'createdBy']);
    }

    function messageFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'chatId',
        'text',
        'type',
        'senderId',
        'timestamp',
        'createdAt',
        'imageUrl',
        'fileUrl',
        'stickerId',
        'stickerUrl',
        'voiceUrl',
        'voiceDuration',
        'isEncrypted',
        'encryptedFor',
        'replyTo',
        'replyToId',
        'replyToText',
        'isForwarded',
        'originalSender',
        'reactions',
        'isTyping',
        'status',
        'readBy'
      ]);
    }

    function validTextMessage() {
      return request.resource.data.type == 'text'
        && ('text' in request.resource.data)
        && nonEmptyStringMax(request.resource.data.text, 10000);
    }

    function validImageMessage() {
      return request.resource.data.type == 'image'
        && nonEmptyStringMax(request.resource.data.imageUrl, 2048)
        && (!('text' in request.resource.data)
          || stringMax(request.resource.data.text, 10000));
    }

    function validStickerMessage() {
      return request.resource.data.type == 'sticker'
        && (
          (('stickerId' in request.resource.data)
            && nonEmptyStringMax(request.resource.data.stickerId, 512))
          || (('stickerUrl' in request.resource.data)
            && nonEmptyStringMax(request.resource.data.stickerUrl, 2048))
        )
        && (!('text' in request.resource.data)
          || stringMax(request.resource.data.text, 10000));
    }

    function validVoiceMessage() {
      return request.resource.data.type == 'voice'
        && nonEmptyStringMax(request.resource.data.voiceUrl, 2048)
        && (!('text' in request.resource.data)
          || stringMax(request.resource.data.text, 10000));
    }

    function validFileMessage() {
      return request.resource.data.type == 'file'
        && nonEmptyStringMax(request.resource.data.fileUrl, 2048)
        && (!('text' in request.resource.data)
          || stringMax(request.resource.data.text, 10000));
    }

    function validMessagePayload() {
      return validTextMessage()
        || validImageMessage()
        || validStickerMessage()
        || validVoiceMessage()
        || validFileMessage();
    }

    function validMessageCreate(chatId) {
      return isChatParticipant(chatId)
        && rateLimitMessageCreate(chatId)
        && messageFieldsOnly()
        && request.resource.data.senderId == request.auth.uid
        && (!('chatId' in request.resource.data)
          || request.resource.data.chatId == chatId)
        && (!('readBy' in request.resource.data)
          || request.resource.data.readBy is list)
        && (!('status' in request.resource.data)
          || request.resource.data.status in ['sending', 'sent', 'delivered', 'read'])
        && (!('encryptedFor' in request.resource.data)
          || request.resource.data.encryptedFor is map)
        && validMessagePayload();
    }

    function validMessageUpdate(chatId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isChatParticipant(chatId)
        && changed.hasOnly([
          'readBy',
          'status',
          'reactions'
        ])
        && (!changed.hasAny(['readBy'])
          || request.resource.data.readBy is list)
        && (!changed.hasAny(['status'])
          || request.resource.data.status in ['sending', 'sent', 'delivered', 'read'])
        && (!changed.hasAny(['reactions'])
          || validReactionsUpdate());
    }

    function validReactionsUpdate() {
      return request.resource.data.reactions is map
        && (
          (('reactions' in resource.data)
            && resource.data.reactions is map
            && request.resource.data.reactions.diff(resource.data.reactions).affectedKeys().hasOnly([request.auth.uid]))
          || (!('reactions' in resource.data)
            && request.resource.data.reactions.keys().hasOnly([request.auth.uid]))
        );
    }

    function validTypingStatusWrite(chatId) {
      return isChatParticipant(chatId)
        && request.resource.data.keys().hasOnly([
          'typingUsers',
          'sendingPhotoUsers',
          'recordingVoiceUsers',
          'updatedAt'
        ])
        && (!('typingUsers' in request.resource.data)
          || request.resource.data.typingUsers is list)
        && (!('sendingPhotoUsers' in request.resource.data)
          || request.resource.data.sendingPhotoUsers is list)
        && (!('recordingVoiceUsers' in request.resource.data)
          || request.resource.data.recordingVoiceUsers is list);
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if validUserCreate(userId);
      allow update: if validUserUpdate(userId);
      allow delete: if false;

      match /chats/{chatId} {
        allow read, create, update: if isSelf(userId);
        allow delete: if false;
      }
    }

    match /publicProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if validPublicProfileWrite(userId);
      allow delete: if false;
    }

    match /typingStatus/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create, update: if validTypingStatusWrite(chatId);
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow get: if signedIn()
        && (
          !chatExists(chatId)
          || request.auth.uid in resource.data.participants
        );
      allow list: if signedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if requestHasCurrentUserParticipant();
      allow update: if safeChatUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if validMessageCreate(chatId);
        allow update: if validMessageUpdate(chatId);
        allow delete: if isChatParticipant(chatId)
          && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
